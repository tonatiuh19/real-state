# Database Configuration (Hostgator MySQL)
DB_HOST=mx50.hostgator.mx
DB_PORT=3306
DB_USER=alanchat_real-admin
DB_PASSWORD=Disrupting2025$
DB_NAME=alanchat_real-state
DB_SSL=false

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Application Settings
NODE_ENV=development
CLIENT_URL=https://real-state-one-omega.vercel.app
BASE_URL=https://real-state-one-omega.vercel.app

# ─── SMTP — Outbound email (HostGator) ───────────────────────────────────────
# Use your HostGator cPanel email credentials.
# SMTP_HOST: found in cPanel → Email Accounts → Connect Devices
# Common values: mail.yourdomain.com  or  box####.hostgator.com
SMTP_HOST=mail.yourdomain.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=no-reply@yourdomain.com
SMTP_PASSWORD=your-email-account-password
SMTP_FROM="Encore Mortgage <no-reply@yourdomain.com>"

# ─── IMAP — Inbound email polling (HostGator) ────────────────────────────────
# Create a dedicated HostGator email account for client replies, e.g. reply@yourdomain.com
# The IMAP credentials are the same as the email account credentials in cPanel.
# IMAP_HOST: same server as SMTP_HOST
# IMAP_PORT: 993 (TLS, recommended) or 143 (STARTTLS)
# IMAP_TLS:  true for port 993, false for port 143
IMAP_HOST=mail.yourdomain.com
IMAP_PORT=993
IMAP_USER=reply@yourdomain.com
IMAP_PASSWORD=your-reply-mailbox-password
IMAP_TLS=true

# ─── Cron secret ─────────────────────────────────────────────────────────────
# Protects the /api/cron/poll-inbound-email endpoint.
# Generate with:  openssl rand -hex 32
# Used by Vercel Cron (auto-sent) AND by the HostGator cURL cron command.
CRON_SECRET=replace-with-openssl-rand-hex-32

# ─── Inbound webhook (alternative — only needed if using Postmark/Mailgun/SendGrid) ─
# Leave blank if using the IMAP polling approach above (recommended for HostGator users).
INBOUND_EMAIL_DOMAIN=
INBOUND_WEBHOOK_SECRET=
