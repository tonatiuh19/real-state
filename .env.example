# Database Configuration
# --- TiDB Cloud Serverless ---
# Get these from: TiDB Cloud Console → Cluster → Connect → "Connect with mysql2"
# DB_HOST: e.g. gateway01.us-east-1.prod.aws.tidbcloud.com
# DB_PORT: 4000 (TiDB default)
# DB_SSL: must be "true" for TiDB Cloud Serverless
DB_HOST=your-tidb-cluster.tidbcloud.com
DB_PORT=4000
DB_USER=your-tidb-username
DB_PASSWORD=your-tidb-password
DB_NAME=your-database-name
DB_SSL=true

# --- HostGator MySQL (legacy, keep for reference) ---
# DB_HOST=your-hostgator-host
# DB_PORT=3306
# DB_USER=your-hostgator-user
# DB_PASSWORD=your-hostgator-password
# DB_NAME=your-database-name
# DB_SSL=false

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Application Settings
NODE_ENV=development
CLIENT_URL=https://real-state-one-omega.vercel.app
BASE_URL=https://real-state-one-omega.vercel.app

# ─── SMTP — Outbound email (HostGator) ───────────────────────────────────────
# Use your HostGator cPanel email credentials.
# SMTP_HOST: found in cPanel → Email Accounts → Connect Devices
# Common values: mail.yourdomain.com  or  box####.hostgator.com
SMTP_HOST=mail.yourdomain.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=no-reply@yourdomain.com
SMTP_PASSWORD=your-email-account-password
SMTP_FROM="Encore Mortgage <no-reply@yourdomain.com>"

# ─── SMTP — Reminder flows only (optional override) ──────────────────────────
# If set, reminder flow send_email steps use these values.
# If not set, reminder flows fall back to SMTP_* above.
REMINDER_SMTP_HOST=mail.your-reminder-domain.com
REMINDER_SMTP_PORT=465
REMINDER_SMTP_SECURE=true
REMINDER_SMTP_USER=no-reply@your-reminder-domain.com
REMINDER_SMTP_PASSWORD=your-reminder-email-password
REMINDER_SMTP_FROM="Encore Mortgage <no-reply@your-reminder-domain.com>"

# ─── IMAP — Inbound email polling (HostGator) ────────────────────────────────
# Create a dedicated HostGator email account for client replies, e.g. reply@yourdomain.com
# The IMAP credentials are the same as the email account credentials in cPanel.
# IMAP_HOST: same server as SMTP_HOST
# IMAP_PORT: 993 (TLS, recommended) or 143 (STARTTLS)
# IMAP_TLS:  true for port 993, false for port 143
IMAP_HOST=mail.yourdomain.com
IMAP_PORT=993
IMAP_USER=reply@yourdomain.com
IMAP_PASSWORD=your-reply-mailbox-password
IMAP_TLS=true

# ─── Cron secret ─────────────────────────────────────────────────────────────
# Protects the /api/cron/poll-inbound-email endpoint.
# Generate with:  openssl rand -hex 32
# Used by Vercel Cron (auto-sent) AND by the HostGator cURL cron command.
CRON_SECRET=replace-with-openssl-rand-hex-32

# ─── Inbound webhook (alternative — only needed if using Postmark/Mailgun/SendGrid) ─
# Leave blank if using the IMAP polling approach above (recommended for HostGator users).
INBOUND_EMAIL_DOMAIN=
INBOUND_WEBHOOK_SECRET=

# ─── Zoom — Server-to-Server OAuth ───────────────────────────────────────────
# 1. Go to https://marketplace.zoom.us → Develop → Build App
# 2. Select "Server-to-Server OAuth" app type
# 3. After creating, enable the scope: meeting:write (or meeting:write:admin)
# 4. Copy Account ID, Client ID, and Client Secret below
# If not set, video meetings will be booked without a Zoom link.
ZOOM_ACCOUNT_ID=your_zoom_account_id
ZOOM_CLIENT_ID=your_zoom_client_id
ZOOM_CLIENT_SECRET=your_zoom_client_secret

# ─── Twilio — SMS verification & messaging ───────────────────────────────────
# 1. Sign up at https://www.twilio.com
# 2. From Console Dashboard copy Account SID and Auth Token
# 3. Buy or use a Twilio phone number for SMS (e.g. +15551234567)
# 4. Optional: separate WhatsApp-enabled number (Twilio Sandbox or approved number)
# If not set, SMS delivery method on login will be disabled.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+15551234567
# TWILIO_WHATSAPP_NUMBER=+15551234567   # Only needed if using WhatsApp messaging
